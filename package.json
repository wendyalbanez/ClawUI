{
  "name": "clawui",
  "version": "0.0.3",
  "description": "A cross-platform desktop application built with Electron, React, TypeScript, and Vite",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "prepare:openclaw": "npx tsx scripts/prepare-openclaw.ts",
    "build:mac": "pnpm build && electron-builder --mac --config electron-builder.config.ts",
    "build:mac:bundled": "pnpm prepare:openclaw && pnpm build && electron-builder --mac --config electron-builder.config.ts",
    "build:win": "pnpm build && electron-builder --win --config electron-builder.config.ts",
    "build:linux": "pnpm build && electron-builder --linux --config electron-builder.config.ts",
    "build:all": "pnpm build && electron-builder --mac --win --linux --config electron-builder.config.ts"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "vite",
    "cross-platform"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "@agentscope-ai/chat": "^1.1.53",
    "@agentscope-ai/design": "^1.0.31",
    "@ant-design/charts": "^2.6.7",
    "antd": "^6.3.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.19.0"
  }
}
